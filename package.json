{
  "name": "x-content-scout",
  "version": "0.1.0",
  "description": "X Account Content Planning Assistant",
  "type": "module",
  "main": "dist/desktop/main.js",
  "scripts": {
    "build": "tsc && npm run copy-files",
    "copy-files": "mkdir -p dist/db && cp src/db/schema.sql dist/db/ && mkdir -p dist/data && cp -r src/data/* dist/data/ && mkdir -p dist/web && cp src/web/*.html dist/web/",
    "dev": "tsx src/main.ts",
    "start": "node dist/main.js",
    "desktop": "npm run build && electron dist/desktop/main.js",
    "desktop:pack": "node scripts/package-desktop.mjs --dir",
    "desktop:dist": "node scripts/package-desktop.mjs",
    "desktop:rebuild": "electron-builder install-app-deps",
    "lint": "eslint src --ext .ts",
    "format": "prettier --write \"src/**/*.ts\"",
    "db:init": "tsx src/db/init.ts",
    "admin": "tsx src/web/admin-server.ts",
    "worker": "tsx src/runtime/worker.ts",
    "test:aggregator": "tsx src/test-aggregator.ts",
    "test:filter": "tsx src/test-filter.ts",
    "test:generator": "tsx src/test-generator-feishu.ts",
    "workflow": "tsx src/workflow.ts"
  },
  "keywords": [
    "x",
    "twitter",
    "content",
    "ai"
  ],
  "author": "",
  "license": "MIT",
  "build": {
    "appId": "app.content-scout.local",
    "productName": "Content Scout",
    "asar": false,
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "package.json",
      "node_modules/**/*"
    ],
    "mac": {
      "target": [
        "dmg",
        "zip"
      ],
      "category": "public.app-category.productivity"
    },
    "win": {
      "target": [
        "nsis"
      ]
    },
    "linux": {
      "target": [
        "AppImage"
      ],
      "category": "Office"
    }
  },
  "dependencies": {
    "@larksuiteoapi/node-sdk": "^1.29.0",
    "@lucasygu/redbook": "^0.7.2",
    "axios": "^1.6.7",
    "better-sqlite3": "^9.4.0",
    "dotenv": "^16.4.0",
    "node-cron": "^3.0.3",
    "openai": "^4.28.0",
    "p-limit": "^5.0.0",
    "puppeteer": "^22.15.0",
    "winston": "^3.11.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.9",
    "@types/node": "^20.11.0",
    "@types/node-cron": "^3.0.11",
    "@typescript-eslint/eslint-plugin": "^6.19.0",
    "@typescript-eslint/parser": "^6.19.0",
    "electron": "^30.5.1",
    "electron-builder": "^26.8.1",
    "eslint": "^8.56.0",
    "prettier": "^3.2.4",
    "tsx": "^4.7.0",
    "typescript": "^5.3.3"
  }
}
