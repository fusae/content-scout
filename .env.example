# Database
DB_PATH=./data/scout.db

# Profile
PROFILE_PATH=./config/profile.local.json

# Logging
LOG_LEVEL=info
LOG_FILE=./logs/app.log

# Embedding（阿里云百炼 OpenAI 兼容接口）
EMBEDDING_API_KEY=your_dashscope_api_key_here
EMBEDDING_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
EMBEDDING_MODEL=text-embedding-v4

# DeepSeek (可选，用于深度画像分析)
DEEPSEEK_API_KEY=your_deepseek_api_key_here
DEEPSEEK_BASE_URL=https://api.deepseek.com

# Content Account
ACCOUNT_HANDLE=example_creator
X_BEARER_TOKEN=

# Sources
ENABLED_SOURCES=hackernews,github,zhihu,reddit,v2ex

# Lark (飞书)
LARK_APP_ID=your_lark_app_id
LARK_APP_SECRET=your_lark_app_secret

# 飞书推送配置
FEISHU_APP_ID=cli_xxx
FEISHU_APP_SECRET=xxx
FEISHU_BOT_NAME=内容策划助手
FEISHU_DEFAULT_RECEIVER_ID=ou_xxx  # 默认接收者的 open_id

# Turing（把推荐转成单任务写作）
TURING_BASE_URL=http://your-server:4590
TURING_API_TOKEN=your_turing_api_token
TURING_ARTICLE_AGENT=opencode
TURING_ARTICLE_CWD=/path/to/article-workspace
# TURING_ARTICLE_RULES=按当前工作区已有写文工作流执行；完成后在 [RESULT]...[/RESULT] 中返回最终文章路径或结果摘要。

# Rate Limiting
MAX_CONCURRENT_REQUESTS=3
REQUEST_DELAY_MS=1000

# Cron Schedule
CRON_SCHEDULE=0 9 * * *
