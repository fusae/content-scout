# Database
DB_PATH=./data/scout.db
ADMIN_PORT=8787
ADMIN_HOST=127.0.0.1
# ADMIN_HOST 非本机地址时必须配置；访问方式：http://host:8787/?token=xxx
ADMIN_TOKEN=
# 本地辅助登录的浏览器数据目录；保留后可复用小红书/抖音登录态
LOCAL_LOGIN_PROFILE_DIR=./data/browser-profiles
LOCAL_SCRAPER_HEADLESS=false
# 可选：手动指定 Chrome/Edge/Brave 路径；Windows 安装版找不到浏览器时再填
LOCAL_BROWSER_EXECUTABLE_PATH=

# Profile
PROFILE_PATH=./config/profile.local.json

# Logging
LOG_LEVEL=info
LOG_FILE=./logs/app.log

# SaaS/多用户模式下必须配置；本地不配置则明文兼容
CREDENTIAL_ENCRYPTION_KEY=replace_with_32_plus_random_chars

# Embedding（阿里云百炼 OpenAI 兼容接口）
EMBEDDING_API_KEY=your_dashscope_api_key_here
EMBEDDING_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
EMBEDDING_MODEL=text-embedding-v4

# DeepSeek (可选，用于深度画像分析)
DEEPSEEK_API_KEY=your_deepseek_api_key_here
DEEPSEEK_BASE_URL=https://api.deepseek.com

# Creator profile
X_ACCOUNT_HANDLE=example_creator
X_BEARER_TOKEN=

# Built-in sources include Hacker News, GitHub Trending, X, Zhihu, Product Hunt,
# Reddit, V2EX, Douyin, Xiaohongshu, and Weibo.
# SaaS 建议先启用这些源；本地留空 ENABLED_SOURCES 则默认启用全部内置源
ENABLED_SOURCES=hackernews,github,zhihu,reddit,v2ex,douyin,xiaohongshu,weibo
DISABLED_SOURCES=
CONTENT_SEARCH_KEYWORDS=AI 工具,工作流自动化,内容创作,独立开发
# 可选：覆盖通用关键词；配置后中文平台会按关键词搜索
ZHIHU_SEARCH_KEYWORDS=
DOUYIN_SEARCH_KEYWORDS=
XIAOHONGSHU_SEARCH_KEYWORDS=
WEIBO_SEARCH_KEYWORDS=
# 抖音关键词搜索：启动 TikTokDownloader Web API 后填写
DOUYIN_TIKTOKDOWNLOADER_API_URL=http://127.0.0.1:5555
DOUYIN_TIKTOKDOWNLOADER_TOKEN=
# 可选：关键词搜索可能需要登录 Cookie；小红书默认使用 redbook 适配器
DOUYIN_COOKIE=
ZHIHU_COOKIE=
XIAOHONGSHU_COOKIE=
WEIBO_COOKIE=
XIAOHONGSHU_ADAPTER=redbook
XIAOHONGSHU_COOKIE_SOURCE=chrome
XIAOHONGSHU_CHROME_PROFILE=

# Lark (飞书)
LARK_APP_ID=your_lark_app_id
LARK_APP_SECRET=your_lark_app_secret

# 飞书推送配置
FEISHU_APP_ID=cli_xxx
FEISHU_APP_SECRET=xxx
FEISHU_BOT_NAME=内容策划助手
FEISHU_DEFAULT_RECEIVER_ID=ou_xxx  # 默认接收者的 open_id

# Rate Limiting
MAX_CONCURRENT_REQUESTS=3
REQUEST_DELAY_MS=1000

# Cron Schedule
CRON_SCHEDULE=0 9 * * *
